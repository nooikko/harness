# Database
DATABASE_URL="postgresql://user:password@localhost:5432/harness?schema=public"

# Next.js
NEXT_PUBLIC_APP_URL="http://localhost:4000"

# Orchestrator
PORT=4001
HEALTH_PORT=4002

# Orchestrator connection (for web dashboard)
ORCHESTRATOR_URL="http://localhost:4001"
# 256-bit AES encryption key as 64 hex characters (required for secret plugin settings)
# Generate with: openssl rand -hex 32
HARNESS_ENCRYPTION_KEY=""
NEXT_PUBLIC_ORCHESTRATOR_WS_URL="ws://localhost:4001/ws"
# Qdrant vector search (optional — search works without it via FTS fallback)
QDRANT_URL="http://localhost:6333"

# Microsoft Graph API (Outlook + Calendar plugins)
# See docs/microsoft-graph-setup.md for App Registration instructions
MICROSOFT_CLIENT_ID=""
MICROSOFT_CLIENT_SECRET=""
MICROSOFT_TENANT_ID="common"
MICROSOFT_REDIRECT_URI="http://localhost:4000/api/oauth/callback"
# 256-bit AES encryption key for OAuth tokens (64 hex characters)
# Generate with: openssl rand -hex 32
OAUTH_ENCRYPTION_KEY=""

CLAUDE_MODEL_DEFAULT=sonnet
LOG_LEVEL=info
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10
