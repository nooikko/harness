{
  "name": "@harness/database",
  "version": "0.1.0",
  "private": true,
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "db:generate": "dotenv -e ../../.env -- prisma generate",
    "db:push": "dotenv -e ../../.env -- prisma db push && pnpm db:search-indexes",
    "db:studio": "dotenv -e ../../.env -- prisma studio",
    "db:migrate": "dotenv -e ../../.env -- prisma migrate dev",
    "db:seed": "dotenv -e ../../.env -- prisma db seed",
    "db:search-indexes": "dotenv -e ../../.env -- prisma db execute --file prisma/search-indexes.sql --schema prisma/schema.prisma",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "typecheck": "tsc --noEmit",
    "postinstall": "dotenv -e ../../.env -- prisma generate || true"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.19.2",
    "dotenv": "^16.6.1"
  },
  "devDependencies": {
    "@harness/vitest-config": "workspace:*",
    "@types/node": "^22.19.11",
    "dotenv-cli": "^11.0.0",
    "prisma": "^6.19.2",
    "tsup": "^8.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
