// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Orchestrator Models ─────────────────────────────────────────────────

model Thread {
  id             String     @id @default(cuid())
  source         String
  sourceId       String
  name           String?
  kind           String     @default("general")
  status         String     @default("open")
  sessionId           String?
  model               String?
  customInstructions  String?
  parentThreadId      String?
  parentThread   Thread?    @relation("ThreadChildren", fields: [parentThreadId], references: [id])
  children       Thread[]   @relation("ThreadChildren")
  messages       Message[]
  tasks          OrchestratorTask[]
  agentRuns      AgentRun[]
  agentId        String?
  agent          Agent?     @relation(fields: [agentId], references: [id])
  lastActivity   DateTime   @default(now())
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@unique([source, sourceId])
  @@index([status, lastActivity])
}

model Message {
  id        String   @id @default(cuid())
  threadId  String
  thread    Thread   @relation(fields: [threadId], references: [id], onDelete: Cascade)
  role      String
  kind      String   @default("text")
  source    String   @default("builtin")
  content   String   @db.Text
  model     String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([threadId, createdAt])
  @@index([threadId, kind])
  @@index([threadId, source])
}

model OrchestratorTask {
  id               String             @id @default(cuid())
  threadId         String
  thread           Thread             @relation(fields: [threadId], references: [id], onDelete: Cascade)
  parentTaskId     String?
  parentTask       OrchestratorTask?  @relation("TaskChildren", fields: [parentTaskId], references: [id])
  children         OrchestratorTask[] @relation("TaskChildren")
  status           String             @default("pending")
  prompt           String             @db.Text
  result           String?            @db.Text
  maxIterations    Int                @default(3)
  currentIteration Int                @default(0)
  agentRuns        AgentRun[]
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  @@index([threadId, status])
}

model AgentRun {
  id           String            @id @default(cuid())
  threadId     String
  thread       Thread            @relation(fields: [threadId], references: [id], onDelete: Cascade)
  taskId       String?
  task         OrchestratorTask? @relation(fields: [taskId], references: [id])
  traceId      String?
  model        String
  inputTokens  Int               @default(0)
  outputTokens Int               @default(0)
  costEstimate Float             @default(0)
  durationMs   Int               @default(0)
  status       String            @default("running")
  error        String?           @db.Text
  startedAt    DateTime          @default(now())
  completedAt  DateTime?

  @@index([threadId, startedAt])
  @@index([taskId])
  @@index([traceId])
}

model CronJob {
  id        String    @id @default(cuid())
  name      String    @unique
  schedule  String
  prompt    String    @db.Text
  enabled   Boolean   @default(true)
  lastRunAt DateTime?
  nextRunAt DateTime?
  threadId  String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([enabled, nextRunAt])
}

model Metric {
  id        String   @id @default(cuid())
  name      String
  value     Float
  tags      Json?
  threadId  String?
  createdAt DateTime @default(now())

  @@index([name, createdAt])
  @@index([threadId])
}

model PluginConfig {
  id         String   @id @default(cuid())
  pluginName String   @unique
  enabled    Boolean  @default(true)
  metadata   Json?
  settings   Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([pluginName])
}

// ── Agent Identity Models ────────────────────────────────────────────────

enum MemoryType {
  EPISODIC
  SEMANTIC
  REFLECTION
}

model Agent {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  version     Int      @default(1)
  enabled     Boolean  @default(true)

  soul        String   @db.Text
  identity    String   @db.Text
  userContext String?  @db.Text

  role        String?
  goal        String?
  backstory   String?  @db.Text

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  threads     Thread[]
  memories    AgentMemory[]
  config      AgentConfig?

  @@index([slug])
  @@index([enabled])
}

model AgentMemory {
  id             String     @id @default(cuid())
  agentId        String
  agent          Agent      @relation(fields: [agentId], references: [id], onDelete: Cascade)

  content        String     @db.Text
  type           MemoryType @default(EPISODIC)
  importance     Int        @default(5)

  threadId        String?
  sourceMemoryIds String[]

  createdAt      DateTime   @default(now())
  lastAccessedAt DateTime   @default(now())

  @@index([agentId, type])
  @@index([agentId, lastAccessedAt])
  @@index([agentId, importance])
}

model AgentConfig {
  id                String   @id @default(cuid())
  agentId           String   @unique
  agent             Agent    @relation(fields: [agentId], references: [id])
  memoryEnabled     Boolean  @default(true)
  reflectionEnabled Boolean  @default(false) // Phase 4 — not yet implemented
  heartbeatEnabled  Boolean  @default(false) // Phase 5 — blocked on cron scheduler
  heartbeatCron     String? // cron expression when heartbeat is wired
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model ThreadAudit {
  id          String   @id @default(cuid())
  threadId    String
  threadName  String?
  extractedAt DateTime @default(now())
  content     String   @db.Text
  metadata    Json?

  @@index([threadId])
  @@index([extractedAt])
}
