// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Orchestrator Models ─────────────────────────────────────────────────

model Thread {
  id             String     @id @default(cuid())
  source         String
  sourceId       String
  name           String?
  kind           String     @default("general")
  status         String     @default("active")
  sessionId           String?
  model               String?
  customInstructions  String?
  parentThreadId      String?
  parentThread   Thread?    @relation("ThreadChildren", fields: [parentThreadId], references: [id])
  children       Thread[]   @relation("ThreadChildren")
  messages       Message[]
  tasks          OrchestratorTask[]
  agentRuns      AgentRun[]
  agentId        String?
  agent          Agent?     @relation(fields: [agentId], references: [id])
  projectId      String?
  project        Project?   @relation(fields: [projectId], references: [id])
  memories       AgentMemory[]
  files          File[]
  lastActivity   DateTime   @default(now())
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@unique([source, sourceId])
  @@index([status, lastActivity])
  @@index([projectId])
}

model Project {
  id           String    @id @default(cuid())
  name         String
  description  String?   @db.Text
  instructions String?   @db.Text
  memory       String?   @db.Text
  model        String?
  threads      Thread[]
  memories     AgentMemory[]
  cronJobs     CronJob[]
  files        File[]
  tasks        UserTask[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([name])
}

model Message {
  id        String   @id @default(cuid())
  threadId  String
  thread    Thread   @relation(fields: [threadId], references: [id], onDelete: Cascade)
  role      String
  kind      String   @default("text")
  source    String   @default("builtin")
  content   String   @db.Text
  metadata  Json?
  files     File[]
  createdAt DateTime @default(now())

  @@index([threadId, createdAt])
  @@index([threadId, kind])
  @@index([threadId, source])
}

model OrchestratorTask {
  id               String             @id @default(cuid())
  threadId         String
  thread           Thread             @relation(fields: [threadId], references: [id], onDelete: Cascade)
  status           String             @default("pending")
  prompt           String             @db.Text
  result           String?            @db.Text
  maxIterations    Int                @default(3)
  currentIteration Int                @default(0)
  agentRuns        AgentRun[]
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  @@index([threadId, status])
}

model AgentRun {
  id           String            @id @default(cuid())
  threadId     String
  thread       Thread            @relation(fields: [threadId], references: [id], onDelete: Cascade)
  taskId       String?
  task         OrchestratorTask? @relation(fields: [taskId], references: [id])
  model        String
  inputTokens  Int               @default(0)
  outputTokens Int               @default(0)
  costEstimate Float             @default(0)
  durationMs   Int               @default(0)
  status       String            @default("running")
  error        String?           @db.Text
  startedAt    DateTime          @default(now())
  completedAt  DateTime?

  @@index([threadId, startedAt])
  @@index([taskId])
}

model CronJob {
  id        String    @id @default(cuid())
  agentId   String
  agent     Agent     @relation(fields: [agentId], references: [id])
  projectId String?
  project   Project?  @relation(fields: [projectId], references: [id])
  name      String    @unique
  schedule  String?
  fireAt    DateTime?
  prompt    String    @db.Text
  enabled   Boolean   @default(true)
  lastRunAt DateTime?
  nextRunAt DateTime?
  threadId  String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([enabled, nextRunAt])
  @@index([agentId])
}

model Metric {
  id        String   @id @default(cuid())
  name      String
  value     Float
  tags      Json?
  threadId  String?
  createdAt DateTime @default(now())

  @@index([name, createdAt])
  @@index([threadId])
}

model PluginConfig {
  id         String   @id @default(cuid())
  pluginName String   @unique
  enabled    Boolean  @default(true)
  settings   Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([pluginName])
}

// ── Agent Identity Models ────────────────────────────────────────────────

enum MemoryType {
  EPISODIC
  SEMANTIC
  REFLECTION
}

enum MemoryScope {
  AGENT
  PROJECT
  THREAD
}

enum FileScope {
  PROJECT
  THREAD
  DECORATIVE
}

model File {
  id            String    @id @default(cuid())
  name          String
  path          String    @unique
  mimeType      String
  size          Int
  scope         FileScope
  extractedText String?   @db.Text

  projectId     String?
  project       Project?  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  threadId      String?
  thread        Thread?   @relation(fields: [threadId], references: [id], onDelete: Cascade)

  agentId       String?
  agent         Agent?    @relation(fields: [agentId], references: [id], onDelete: Cascade)

  messageId     String?
  message       Message?  @relation(fields: [messageId], references: [id], onDelete: SetNull)

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([projectId, scope])
  @@index([threadId, scope])
  @@index([agentId, scope])
  @@index([messageId])
}

model Agent {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  version     Int      @default(1)
  enabled     Boolean  @default(true)

  soul        String   @db.Text
  identity    String   @db.Text
  userContext String?  @db.Text

  role        String?
  goal        String?
  backstory   String?  @db.Text

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  threads     Thread[]
  memories    AgentMemory[]
  config      AgentConfig?
  cronJobs    CronJob[]
  files       File[]

  @@index([slug])
  @@index([enabled])
}

model AgentMemory {
  id             String      @id @default(cuid())
  agentId        String
  agent          Agent       @relation(fields: [agentId], references: [id], onDelete: Cascade)

  content        String      @db.Text
  type           MemoryType  @default(EPISODIC)
  scope          MemoryScope @default(AGENT)
  importance     Int         @default(5)

  threadId        String?
  thread          Thread?     @relation(fields: [threadId], references: [id], onDelete: SetNull)
  projectId       String?
  project         Project?    @relation(fields: [projectId], references: [id], onDelete: SetNull)
  sourceMemoryIds String[]

  createdAt      DateTime    @default(now())
  lastAccessedAt DateTime    @default(now())

  @@index([agentId, type])
  @@index([agentId, lastAccessedAt])
  @@index([agentId, importance])
  @@index([agentId, scope])
  @@index([agentId, projectId, scope])
  @@index([agentId, threadId, scope])
}

model AgentConfig {
  id                String   @id @default(cuid())
  agentId           String   @unique
  agent             Agent    @relation(fields: [agentId], references: [id])
  memoryEnabled     Boolean  @default(true)
  reflectionEnabled Boolean  @default(false) // Phase 4 — trigger wired, retrieval boost pending
  bootstrapped      Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model ThreadAudit {
  id          String   @id @default(cuid())
  threadId    String
  threadName  String?
  extractedAt DateTime @default(now())
  content     String   @db.Text
  metadata    Json?

  @@index([threadId])
  @@index([extractedAt])
}

// ── Task Management Models ────────────────────────────────────────────────

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model UserTask {
  id              String         @id @default(cuid())
  title           String
  description     String?        @db.Text
  status          TaskStatus     @default(TODO)
  priority        TaskPriority   @default(MEDIUM)
  dueDate         DateTime?

  sourceMessageId String?
  sourceThreadId  String?

  projectId       String?
  project         Project?       @relation(fields: [projectId], references: [id], onDelete: SetNull)

  createdBy       String         @default("user")

  blockedBy       UserTaskDependency[] @relation("DependentTask")
  blocks          UserTaskDependency[] @relation("BlockingTask")

  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  completedAt     DateTime?

  @@index([status])
  @@index([projectId, status])
  @@index([sourceThreadId])
}

model UserTaskDependency {
  id          String   @id @default(cuid())
  dependentId String
  dependent   UserTask @relation("DependentTask", fields: [dependentId], references: [id], onDelete: Cascade)
  dependsOnId String
  dependsOn   UserTask @relation("BlockingTask", fields: [dependsOnId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@unique([dependentId, dependsOnId])
}

model UserProfile {
  id        String   @id @default("singleton")
  name      String   @default("User")
  pronouns  String?
  age       Int?
  gender    String?
  location  String?
  interests String?
  bio       String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ── OAuth Token Storage ──────────────────────────────────────────────────

model OAuthToken {
  id           String   @id @default(cuid())
  provider     String
  accountId    String
  accessToken  String   @db.Text
  refreshToken String?  @db.Text
  expiresAt    DateTime
  scopes       String[]
  metadata     Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([provider, accountId])
  @@index([provider])
}

// ── Calendar Models ──────────────────────────────────────────────────────

enum CalendarEventSource {
  OUTLOOK
  GOOGLE
  LOCAL
  MEMORY
  TASK
  CRON
}

model CalendarEvent {
  id            String              @id @default(cuid())
  externalId    String?
  source        CalendarEventSource
  title         String
  description   String?             @db.Text
  startAt       DateTime
  endAt         DateTime
  isAllDay      Boolean             @default(false)
  location      String?
  joinUrl       String?
  recurrence    String?
  color         String?
  category      String?
  attendees     Json?
  organizer     String?
  isCancelled   Boolean             @default(false)
  webLink       String?
  importance    String?             // "low" | "normal" | "high"
  sensitivity   String?             // "normal" | "private" | "confidential"
  reminder      Int?                // minutes before event

  sourceMemoryId String?
  sourceTaskId   String?
  sourceCronId   String?

  calendarId    String?
  lastSyncedAt  DateTime?
  changeKey     String?

  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@unique([source, externalId])
  @@index([startAt, endAt])
  @@index([source])
  @@index([category])
}

model CalendarSyncState {
  id            String   @id @default(cuid())
  calendarId    String   @unique
  deltaLink     String?  @db.Text
  lastSyncAt    DateTime?
  syncStatus    String   @default("idle")
  errorMessage  String?
  metadata      Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ── Error Logging ─────────────────────────────────────────────────────────

model ErrorLog {
  id        String   @id @default(cuid())
  level     String   // 'error' | 'warn'
  source    String   // plugin name, 'orchestrator', 'web'
  message   String   @db.Text
  stack     String?  @db.Text
  traceId   String?
  threadId  String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([source])
  @@index([level])
  @@index([createdAt])
  @@index([traceId])
}
