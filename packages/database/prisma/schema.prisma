// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Orchestrator Models ─────────────────────────────────────────────────

model Thread {
  id             String     @id @default(cuid())
  source         String
  sourceId       String
  name           String?
  kind           String     @default("general")
  status         String     @default("active")
  sessionId           String?
  model               String?
  effort              String?
  customInstructions  String?
  parentThreadId      String?
  parentThread   Thread?    @relation("ThreadChildren", fields: [parentThreadId], references: [id])
  children       Thread[]   @relation("ThreadChildren")
  messages       Message[]
  tasks          OrchestratorTask[]
  agentRuns      AgentRun[]
  agentId        String?
  agent          Agent?     @relation(fields: [agentId], references: [id])
  projectId      String?
  project        Project?   @relation(fields: [projectId], references: [id])
  storyId        String?
  story          Story?     @relation(fields: [storyId], references: [id], onDelete: SetNull)
  memories       AgentMemory[]
  files          File[]
  lastActivity   DateTime   @default(now())
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@unique([source, sourceId])
  @@index([status, lastActivity])
  @@index([projectId])
  @@index([storyId])
}

model Project {
  id           String    @id @default(cuid())
  name         String
  description  String?   @db.Text
  instructions String?   @db.Text
  memory       String?   @db.Text
  model        String?
  threads      Thread[]
  memories     AgentMemory[]
  cronJobs     CronJob[]
  files        File[]
  tasks        UserTask[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([name])
}

model Message {
  id        String   @id @default(cuid())
  threadId  String
  thread    Thread   @relation(fields: [threadId], references: [id], onDelete: Cascade)
  role      String
  kind      String   @default("text")
  source    String   @default("builtin")
  content   String   @db.Text
  metadata      Json?
  files         File[]
  storyMoments  StoryMoment[]
  annotation    MessageAnnotation?
  createdAt     DateTime @default(now())

  @@index([threadId, createdAt])
  @@index([threadId, kind])
  @@index([threadId, source])
}

model MessageAnnotation {
  id        String   @id @default(cuid())
  messageId String   @unique
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  agentId   String?
  agent     Agent?   @relation(fields: [agentId], references: [id], onDelete: SetNull)
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([agentId])
}

model OrchestratorTask {
  id               String             @id @default(cuid())
  threadId         String
  thread           Thread             @relation(fields: [threadId], references: [id], onDelete: Cascade)
  status           String             @default("pending")
  prompt           String             @db.Text
  result           String?            @db.Text
  maxIterations    Int                @default(3)
  currentIteration Int                @default(0)
  agentRuns        AgentRun[]
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  @@index([threadId, status])
}

model AgentRun {
  id           String            @id @default(cuid())
  threadId     String
  thread       Thread            @relation(fields: [threadId], references: [id], onDelete: Cascade)
  taskId       String?
  task         OrchestratorTask? @relation(fields: [taskId], references: [id])
  model        String
  inputTokens  Int               @default(0)
  outputTokens Int               @default(0)
  costEstimate Float             @default(0)
  durationMs   Int               @default(0)
  status       String            @default("running")
  error        String?           @db.Text
  startedAt    DateTime          @default(now())
  completedAt  DateTime?

  @@index([threadId, startedAt])
  @@index([taskId])
}

model CronJob {
  id        String    @id @default(cuid())
  agentId   String
  agent     Agent     @relation(fields: [agentId], references: [id])
  projectId String?
  project   Project?  @relation(fields: [projectId], references: [id])
  name      String    @unique
  schedule  String?
  fireAt    DateTime?
  prompt    String    @db.Text
  enabled   Boolean   @default(true)
  lastRunAt DateTime?
  nextRunAt DateTime?
  threadId  String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([enabled, nextRunAt])
  @@index([agentId])
}

model Metric {
  id        String   @id @default(cuid())
  name      String
  value     Float
  tags      Json?
  threadId  String?
  createdAt DateTime @default(now())

  @@index([name, createdAt])
  @@index([threadId])
}

model PluginConfig {
  id         String   @id @default(cuid())
  pluginName String   @unique
  enabled    Boolean  @default(true)
  settings   Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([pluginName])
}

// ── Agent Identity Models ────────────────────────────────────────────────

enum MemoryType {
  EPISODIC
  SEMANTIC
  REFLECTION
}

enum MemoryScope {
  AGENT
  PROJECT
  THREAD
}

enum FileScope {
  PROJECT
  THREAD
  DECORATIVE
}

model File {
  id            String    @id @default(cuid())
  name          String
  path          String    @unique
  mimeType      String
  size          Int
  scope         FileScope
  extractedText String?   @db.Text

  projectId     String?
  project       Project?  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  threadId      String?
  thread        Thread?   @relation(fields: [threadId], references: [id], onDelete: Cascade)

  agentId       String?
  agent         Agent?    @relation(fields: [agentId], references: [id], onDelete: Cascade)

  messageId     String?
  message       Message?  @relation(fields: [messageId], references: [id], onDelete: SetNull)

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([projectId, scope])
  @@index([threadId, scope])
  @@index([agentId, scope])
  @@index([messageId])
}

model Agent {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  version     Int      @default(1)
  enabled     Boolean  @default(true)

  soul        String   @db.Text
  identity    String   @db.Text
  userContext String?  @db.Text

  role        String?
  goal        String?
  backstory   String?  @db.Text

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  threads     Thread[]
  memories    AgentMemory[]
  config      AgentConfig?
  cronJobs    CronJob[]
  files       File[]
  stories     Story[]
  annotations MessageAnnotation[]

  @@index([slug])
  @@index([enabled])
}

model AgentMemory {
  id             String      @id @default(cuid())
  agentId        String
  agent          Agent       @relation(fields: [agentId], references: [id], onDelete: Cascade)

  content        String      @db.Text
  type           MemoryType  @default(EPISODIC)
  scope          MemoryScope @default(AGENT)
  importance     Int         @default(5)

  threadId        String?
  thread          Thread?     @relation(fields: [threadId], references: [id], onDelete: SetNull)
  projectId       String?
  project         Project?    @relation(fields: [projectId], references: [id], onDelete: SetNull)
  sourceMemoryIds String[]

  createdAt      DateTime    @default(now())
  lastAccessedAt DateTime    @default(now())

  @@index([agentId, type])
  @@index([agentId, lastAccessedAt])
  @@index([agentId, importance])
  @@index([agentId, scope])
  @@index([agentId, projectId, scope])
  @@index([agentId, threadId, scope])
}

model AgentConfig {
  id                String   @id @default(cuid())
  agentId           String   @unique
  agent             Agent    @relation(fields: [agentId], references: [id])
  memoryEnabled     Boolean  @default(true)
  reflectionEnabled Boolean  @default(false) // Phase 4 — trigger wired, retrieval boost pending
  bootstrapped      Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model ThreadAudit {
  id          String   @id @default(cuid())
  threadId    String
  threadName  String?
  extractedAt DateTime @default(now())
  content     String   @db.Text
  metadata    Json?

  @@index([threadId])
  @@index([extractedAt])
}

// ── Task Management Models ────────────────────────────────────────────────

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model UserTask {
  id              String         @id @default(cuid())
  title           String
  description     String?        @db.Text
  status          TaskStatus     @default(TODO)
  priority        TaskPriority   @default(MEDIUM)
  dueDate         DateTime?

  sourceMessageId String?
  sourceThreadId  String?

  projectId       String?
  project         Project?       @relation(fields: [projectId], references: [id], onDelete: SetNull)

  createdBy       String         @default("user")

  blockedBy       UserTaskDependency[] @relation("DependentTask")
  blocks          UserTaskDependency[] @relation("BlockingTask")

  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  completedAt     DateTime?

  @@index([status])
  @@index([projectId, status])
  @@index([sourceThreadId])
}

model UserTaskDependency {
  id          String   @id @default(cuid())
  dependentId String
  dependent   UserTask @relation("DependentTask", fields: [dependentId], references: [id], onDelete: Cascade)
  dependsOnId String
  dependsOn   UserTask @relation("BlockingTask", fields: [dependsOnId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@unique([dependentId, dependsOnId])
}

model UserProfile {
  id        String   @id @default("singleton")
  name      String   @default("User")
  pronouns  String?
  age       Int?
  gender    String?
  location  String?
  interests String?
  bio       String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ── OAuth Token Storage ──────────────────────────────────────────────────

model OAuthToken {
  id           String   @id @default(cuid())
  provider     String
  accountId    String
  accessToken  String   @db.Text
  refreshToken String?  @db.Text
  expiresAt    DateTime
  scopes       String[]
  metadata     Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([provider, accountId])
  @@index([provider])
}

// ── Calendar Models ──────────────────────────────────────────────────────

enum CalendarEventSource {
  OUTLOOK
  GOOGLE
  LOCAL
  MEMORY
  TASK
  CRON
}

model CalendarEvent {
  id            String              @id @default(cuid())
  externalId    String?
  source        CalendarEventSource
  title         String
  description   String?             @db.Text
  startAt       DateTime
  endAt         DateTime
  isAllDay      Boolean             @default(false)
  location      String?
  joinUrl       String?
  recurrence    String?
  color         String?
  category      String?
  attendees     Json?
  organizer     String?
  isCancelled   Boolean             @default(false)
  webLink       String?
  importance    String?             // "low" | "normal" | "high"
  sensitivity   String?             // "normal" | "private" | "confidential"
  reminder      Int?                // minutes before event

  sourceMemoryId String?
  sourceTaskId   String?
  sourceCronId   String?

  calendarId    String?
  lastSyncedAt  DateTime?
  changeKey     String?

  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@unique([source, externalId])
  @@index([startAt, endAt])
  @@index([source])
  @@index([category])
}

model CalendarSyncState {
  id            String   @id @default(cuid())
  calendarId    String   @unique
  deltaLink     String?  @db.Text
  lastSyncAt    DateTime?
  syncStatus    String   @default("idle")
  errorMessage  String?
  metadata      Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ── Error Logging ─────────────────────────────────────────────────────────

model ErrorLog {
  id        String   @id @default(cuid())
  level     String   // 'error' | 'warn'
  source    String   // plugin name, 'orchestrator', 'web'
  message   String   @db.Text
  stack     String?  @db.Text
  traceId   String?
  threadId  String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([source])
  @@index([level])
  @@index([createdAt])
  @@index([traceId])
}

// ── SSH Plugin ──────────────────────────────────────────────────────────

model SshHost {
  id          String    @id @default(cuid())
  name        String    @unique
  hostname    String
  port        Int       @default(22)
  username    String
  authMethod  String    @default("key") // "key" or "password"
  privateKey  String?   @db.Text // PEM-encoded, encrypted at rest
  fingerprint String?   // Host key fingerprint (TOFU)
  tags        String[]
  enabled     Boolean   @default(true)
  lastSeenAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  commandLogs SshCommandLog[]

  @@index([name])
  @@index([enabled])
}

model SshCommandLog {
  id        String   @id @default(cuid())
  hostId    String
  host      SshHost  @relation(fields: [hostId], references: [id], onDelete: Cascade)
  command   String   @db.Text
  exitCode  Int?
  stdout    String?  @db.Text
  stderr    String?  @db.Text
  duration  Int?     // milliseconds
  threadId  String?
  agentId   String?
  createdAt DateTime @default(now())

  @@index([hostId, createdAt])
  @@index([threadId])
}

// ── Storytelling Models ──────────────────────────────────────────────────

enum ArcStatus {
  building
  climaxed
  resolved
  dormant
}

model Story {
  id           String           @id @default(cuid())
  name         String
  premise      String?          @db.Text
  storyTime    String?
  currentScene Json?
  agentId      String?
  agent        Agent?           @relation(fields: [agentId], references: [id])
  threads      Thread[]
  characters   StoryCharacter[]
  moments      StoryMoment[]
  locations    StoryLocation[]
  arcs         StoryArc[]
  transcripts  StoryTranscript[]
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@index([agentId])
}

model StoryCharacter {
  id           String             @id @default(cuid())
  storyId      String
  story        Story              @relation(fields: [storyId], references: [id], onDelete: Cascade)
  name         String
  aliases      String[]
  appearance   String?            @db.Text
  personality  String?            @db.Text
  mannerisms   String?            @db.Text
  motives      String?            @db.Text
  backstory    String?            @db.Text
  relationships String?           @db.Text
  color        String?
  status       String             @default("active")
  importNotes  String?            @db.Text
  firstSeenAt  DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  moments      CharacterInMoment[]

  @@unique([storyId, name])
  @@index([storyId, status])
}

model StoryLocation {
  id            String                 @id @default(cuid())
  storyId       String
  story         Story                  @relation(fields: [storyId], references: [id], onDelete: Cascade)
  name          String
  description   String?                @db.Text
  parentId      String?
  parent        StoryLocation?         @relation("LocationContainment", fields: [parentId], references: [id])
  children      StoryLocation[]        @relation("LocationContainment")
  moments       StoryMoment[]
  relationsFrom LocationRelationship[] @relation("RelationshipFrom")
  relationsTo   LocationRelationship[] @relation("RelationshipTo")

  @@unique([storyId, name])
  @@index([storyId])
  @@index([parentId])
}

model LocationRelationship {
  id        String        @id @default(cuid())
  fromId    String
  from      StoryLocation @relation("RelationshipFrom", fields: [fromId], references: [id], onDelete: Cascade)
  toId      String
  to        StoryLocation @relation("RelationshipTo", fields: [toId], references: [id], onDelete: Cascade)
  distance  String?
  direction String?
  notes     String?

  @@unique([fromId, toId])
}

model StoryMoment {
  id                 String             @id @default(cuid())
  storyId            String
  story              Story              @relation(fields: [storyId], references: [id], onDelete: Cascade)
  summary            String             @db.Text
  description        String?            @db.Text
  storyTime          String?
  locationId         String?
  location           StoryLocation?     @relation(fields: [locationId], references: [id], onDelete: SetNull)
  kind               String
  importance         Int                @default(5)
  messageId          String?
  message            Message?           @relation(fields: [messageId], references: [id], onDelete: SetNull)
  characters         CharacterInMoment[]
  arcs               MomentInArc[]
  sourceTranscriptId String?
  sourceTranscript   StoryTranscript?   @relation(fields: [sourceTranscriptId], references: [id], onDelete: SetNull)
  sourceChunkIndex   Int?
  sourceNotes        String?            @db.Text
  annotation         String?            @db.Text
  deletedAt          DateTime?
  mergedIntoId       String?
  createdAt          DateTime           @default(now())

  @@index([storyId, createdAt])
  @@index([storyId, importance])
  @@index([locationId])
  @@index([sourceTranscriptId, sourceChunkIndex])
  @@index([deletedAt])
}

model CharacterInMoment {
  id              String          @id @default(cuid())
  characterId     String?
  character       StoryCharacter? @relation(fields: [characterId], references: [id], onDelete: SetNull)
  characterName   String
  momentId        String
  moment          StoryMoment     @relation(fields: [momentId], references: [id], onDelete: Cascade)
  role            String
  perspective     String?         @db.Text
  emotionalImpact     String?         @db.Text
  knowledgeGained     String?         @db.Text
  relationshipContext String?         @db.Text

  @@unique([characterId, momentId])
  @@index([characterId])
  @@index([momentId])
}

model StoryArc {
  id          String      @id @default(cuid())
  storyId     String
  story       Story       @relation(fields: [storyId], references: [id], onDelete: Cascade)
  name        String
  description String?     @db.Text
  status      ArcStatus   @default(building)
  importance  Int         @default(5)
  annotation  String?     @db.Text
  moments     MomentInArc[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@unique([storyId, name])
  @@index([storyId, status])
}

model MomentInArc {
  id       String      @id @default(cuid())
  arcId    String
  arc      StoryArc    @relation(fields: [arcId], references: [id], onDelete: Cascade)
  momentId String
  moment   StoryMoment @relation(fields: [momentId], references: [id], onDelete: Cascade)
  position Float       @default(0)
  note     String?     @db.Text

  @@unique([arcId, momentId])
  @@index([arcId, position])
  @@index([momentId])
}

model StoryTranscript {
  id               String        @id @default(cuid())
  storyId          String
  story            Story         @relation(fields: [storyId], references: [id], onDelete: Cascade)
  label            String
  sourceType       String        @default("claude")
  rawContent       String        @db.Text
  processed        Boolean       @default(false)
  processedThrough Int?
  totalChunks      Int?
  messageCount     Int?
  moments          StoryMoment[]
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@index([storyId])
}
